{
  "name": "dexe-mcp",
  "version": "0.1.3",
  "description": "MCP server wrapping DeXe Protocol for Claude Code dev tooling (build/test, contract introspection, governance-domain tools)",
  "type": "module",
  "license": "MIT",
  "author": "Edward Arinin <edward.arinin@gmail.com>",
  "homepage": "https://github.com/edward-arinin-web-dev/dexe-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edward-arinin-web-dev/dexe-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/edward-arinin-web-dev/dexe-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "hardhat",
    "solidity",
    "ethereum",
    "dexe",
    "dao",
    "governance",
    "smart-contracts",
    "dev-tools"
  ],
  "bin": {
    "dexe-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "FUTURE.md",
    "PLAN.md",
    ".mcp.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ethers": "^6.13.0",
    "execa": "^9.5.0",
    "p-limit": "^6.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
