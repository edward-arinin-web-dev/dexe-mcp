{
  "name": "dexe-mcp",
  "version": "0.8.0",
  "description": "MCP server for the DeXe Protocol — full DAO operations coverage: deploy DAOs, build every proposal type, IPFS metadata, stake/vote/delegate/execute/claim calldata. Plus dev tooling (build/test/introspect/decode).",
  "type": "module",
  "license": "MIT",
  "author": "Edward Arinin <edward.arinin@gmail.com>",
  "homepage": "https://github.com/edward-arinin-web-dev/dexe-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edward-arinin-web-dev/dexe-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/edward-arinin-web-dev/dexe-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "hardhat",
    "solidity",
    "ethereum",
    "dexe",
    "dao",
    "governance",
    "smart-contracts",
    "dev-tools",
    "dao-operations",
    "proposals",
    "ipfs",
    "pinata",
    "calldata-builder"
  ],
  "bin": {
    "dexe-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "FUTURE.md",
    "SECURITY.md",
    "LICENSE",
    ".mcp.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "doctor": "node dist/index.js doctor",
    "init": "node dist/index.js init",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:compat": "node tests/compat/diff-otc.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "swarm:preflight": "tsx scripts/swarm/preflight.ts",
    "swarm:fund": "tsx scripts/swarm/fund-pool.ts",
    "swarm:run": "tsx scripts/swarm/orchestrator.ts",
    "swarm:smoke": "tsx scripts/swarm/orchestrator.ts --scenarios=S00-reset,S01-delegation-chain-3hop --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@walletconnect/universal-provider": "^2.17.0",
    "ethers": "^6.13.0",
    "execa": "^9.5.0",
    "multiformats": "^13.4.2",
    "p-limit": "^6.2.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-slate-transformer": "^0.9.0",
    "unified": "^11.0.5",
    "zod": "^3.23.8"
  },
  "overrides": {
    "fast-uri": ">=3.1.2",
    "hono": ">=4.12.18",
    "ip-address": ">=10.1.1",
    "express-rate-limit": ">=8.4.0",
    "esbuild": ">=0.25.0",
    "ws": ">=8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
