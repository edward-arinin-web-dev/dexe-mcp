{
  "id": "S55-token-transfer-execute",
  "title": "token_transfer — build → create → on-chain validation",
  "priority": 2,
  "dao": "{{firstAllowlistedDao}}",
  "dependsOn": [],
  "requiresChain": [56, 97],
  "requiresBrowser": false,
  "notes": "Most-used proposal type. Validates ERC20.transfer action emission + blacklist precheck path. Companion to S16 (build-only) but goes through full proposal_create flow.",
  "agents": [
    { "alias": "P", "role": "Proposer", "wallet": "AGENT_PK_1" }
  ],
  "steps": [
    {
      "step": 1,
      "agent": "P",
      "tool": "dexe_proposal_build_token_transfer",
      "args": {
        "govPool": "{{dao}}",
        "token": "{{firstAllowlistedToken}}",
        "recipient": "{{agent:P:address}}",
        "amount": "1000000000000000000",
        "proposalName": "S55 token_transfer validator",
        "proposalDescription": "End-to-end ERC20.transfer proposal — happy path"
      },
      "broadcast": false,
      "captureAs": "built"
    },
    {
      "step": 2,
      "agent": "P",
      "tool": "dexe_proposal_create",
      "args": {
        "govPool": "{{dao}}",
        "proposalType": "custom",
        "title": "S55 token_transfer validator",
        "description": "End-to-end ERC20.transfer proposal",
        "category": "Token Transfer",
        "actionsOnFor": "{{built.actions}}",
        "proposalMetadataExtra": "{{built.metadata}}",
        "user": "{{agent:P:address}}"
      },
      "broadcast": true,
      "captureAs": "created"
    },
    {
      "step": 3,
      "agent": "P",
      "tool": "dexe_proposal_state",
      "args": { "govPool": "{{dao}}", "proposalId": "{{created.proposalId}}" },
      "broadcast": false,
      "captureAs": "state"
    }
  ],
  "successCriteria": [
    { "id": "proposal-id-assigned", "check": "created.proposalId is a positive integer" },
    { "id": "proposal-accepted-on-chain", "check": "state.state in ['Voting', 'SucceededFor', 'ExecutedFor']" }
  ]
}
