{
  "id": "S18-withdraw-treasury-build",
  "title": "Build a Withdraw from Treasury proposal",
  "priority": 2,
  "dao": "{{firstAllowlistedDao}}",
  "dependsOn": [],
  "requiresChain": [56, 97],
  "requiresBrowser": false,
  "notes": "Build-only sanity for the v0.5.6 rewrite — emits external ERC20.transfer with GovPool as the from-address (treasury lives in GovPool as a regular ERC20 balance). Token arg is now mandatory.",
  "agents": [{ "alias": "A", "role": "Voter1/Delegator", "wallet": "AGENT_PK_2" }],
  "steps": [
    {
      "step": 1,
      "agent": "A",
      "tool": "dexe_proposal_build_withdraw_treasury",
      "args": {
        "govPool": "{{dao}}",
        "token": "{{firstAllowlistedToken}}",
        "receiver": "{{agent:A:address}}",
        "amount": "1000000000000000000",
        "nftIds": [],
        "proposalName": "S18 withdraw 1 token from treasury"
      },
      "broadcast": false,
      "captureAs": "built"
    }
  ],
  "successCriteria": [{ "id": "returns", "check": "built returns metadata + actions" }]
}
