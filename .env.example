# ─────────────────────────────────────────────────────────────────────────
# dexe-mcp environment example
#
# EVERYTHING IN THIS FILE IS OPTIONAL. dexe-mcp ships zero-config public
# defaults — on-chain READS, subgraph reads, the DeXe backend, IPFS reads, and
# WalletConnect signing all work with NO .env at all. Copy this to `.env` only
# to override a default, enable IPFS uploads (Pinata JWT), or add a signer.
#
# The MCP server self-loads `.env` via `process.loadEnvFile()` in src/index.ts.
# Restart Claude Code after editing. Run `dexe_doctor` (or `/dexe-setup`) to
# verify. Every value below overrides its baked default.
# ─────────────────────────────────────────────────────────────────────────

# ── RPC (optional — defaults to public BSC nodes for chains 56 + 97) ──────
# No RPC set → the server seeds public BSC dataseed endpoints (default chain
# 56). Public nodes rate-limit and lack archive history; set your own for
# reliability (Alchemy / QuickNode / Ankr).
# DEXE_RPC_URL_MAINNET=https://bsc-dataseed.bnbchain.org
# DEXE_RPC_URL_TESTNET=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# Default chain when a tool omits chainId. Must match a configured/seeded chain.
# DEXE_DEFAULT_CHAIN_ID=56
# Set to 1 to turn OFF the public-RPC fallback entirely.
# DEXE_DISABLE_PUBLIC_RPC=1
# Legacy single-chain form (still supported). Prefer the *_MAINNET/_TESTNET vars.
# DEXE_RPC_URL=https://bsc-dataseed.bnbchain.org
# DEXE_CHAIN_ID=56
# Override the ContractsRegistry root for the default chain (rarely needed;
# chain 56 has a baked default).
# DEXE_CONTRACTS_REGISTRY=

# ── Signer (optional — WalletConnect is available by default) ─────────────
# With no key, signing runs via WalletConnect on a shared default project id:
# run `dexe_wc_connect` and approve each tx on your phone. Set your own id to
# stop sharing the default (free at cloud.reown.com).
# DEXE_WALLETCONNECT_PROJECT_ID=<your-reown-project-id>
# DEXE_WALLETCONNECT_RELAY_URL=wss://relay.walletconnect.com
# DEXE_WALLETCONNECT_APPROVAL_TIMEOUT_MS=120000
# Hot key — plaintext on disk, opt-in only. Anyone who reads this file can
# drain the wallet. Prefer WalletConnect (above) or a Safe multisig (below).
# DEXE_PRIVATE_KEY=0x<your-64-hex-key>
# Signer broadcast guards (only meaningful with a hot key):
# DEXE_SIGNER_ALLOWLIST=0xRecipientA,0xRecipientB
# DEXE_SIGNER_MAX_VALUE_WEI=
# DEXE_SIGNER_MAX_BROADCASTS_PER_MIN=
# Safe multisig transaction service (proposes tx to a Safe; owners co-sign):
# DEXE_SAFE_TX_SERVICE_URL=https://api.safe.global/tx-service/bnb/api/v2
# DEXE_SAFE_API_KEY=

# ── IPFS uploads (Pinata JWT — the one thing reads can't default around) ──
# Required to CREATE DAOs / proposals (they pin metadata to IPFS). Reads work
# without it. Free JWT at https://app.pinata.cloud → API Keys → New Key
# (enable pinJSONToIPFS + pinFileToIPFS).
# DEXE_PINATA_JWT=<your-pinata-jwt>
# IPFS READS default to public gateways (ipfs.io, dweb.link, cloudflare). Set a
# dedicated gateway for reliability (Pinata gives one free with your JWT).
# DEXE_IPFS_GATEWAY=https://<your-subdomain>.mypinata.cloud
# Extra comma-separated read fallbacks appended to the list.
# DEXE_IPFS_GATEWAYS_FALLBACK=https://dweb.link,https://ipfs.io
# Set to 1 to disable the public IPFS read-gateway default (then DEXE_IPFS_GATEWAY required).
# DEXE_IPFS_DISABLE_PUBLIC_FALLBACK=1
# Auth token for a Restricted Pinata dedicated gateway (NOT the pinning JWT).
# DEXE_PINATA_GATEWAY_TOKEN=
# Optional override for the avatar-fetch gateway.
# DEXE_IPFS_AVATAR_GATEWAY=

# ── Subgraph endpoints (optional — default to DeXe public gateway URLs) ───
# Reads default to shared DeXe subgraph URLs (The Graph decentralized gateway,
# key embedded in the URL path). Fine for light use; the shared key is rate-
# limited and billable-shared — set your own for production. Two URL shapes:
#   1. key in path:    …/api/<key>/subgraphs/id/<id>   (key auto-extracted)
#   2. bearer-only:    …/api/subgraphs/id/<id>  +  DEXE_GRAPH_API_KEY
# DEXE_SUBGRAPH_POOLS_URL=https://gateway.thegraph.com/api/<key>/subgraphs/id/<pools-id>
# DEXE_SUBGRAPH_VALIDATORS_URL=https://gateway.thegraph.com/api/<key>/subgraphs/id/<validators-id>
# DEXE_SUBGRAPH_INTERACTIONS_URL=https://gateway.thegraph.com/api/<key>/subgraphs/id/<interactions-id>
# DEXE_GRAPH_API_KEY=<your-graph-api-key>

# ── Off-chain backend (optional — defaults to https://api.dexe.io) ────────
# DEXE_BACKEND_API_URL=https://api.dexe.io

# ── Treasury-safety advisory (low-quorum governance check) ───────────────
# Advisory ONLY — alerts a legit operator/agent to a risky treasury proposal;
# it never blocks (an attacker bypasses the MCP; the durable fix is an in-
# contract min-quorum floor). Minimum safe quorum percent (0–100): proposals/
# DAOs below this are flagged. Default 50.
# DEXE_MIN_SAFE_QUORUM_PCT=50
# Guard posture: off | warn. warn (default) = advisories/alerts everywhere
# (build, deploy, execute, risk_assess); off = silent. Never blocks.
# DEXE_TREASURY_GUARD=warn
# Top-N token holders (by voting weight) in the "controlling set" (alongside
# validators). risk_assess/execute alert when NO controlling member voted For.
# Subgraph + mainnet (56) only; informational, never blocks. Default 5.
# DEXE_CONTROLLING_TOPN=5

# ── Tool surface + state (optional) ──────────────────────────────────────
# Tool profiles to load (comma list): core, proposals, read, vote, governor,
# dev, or full. Default "core,proposals" (slim). "full" or an unknown name
# loads everything. Cuts tools/list tokens per session. Restart after editing.
# DEXE_TOOLSETS=core,proposals
# Persistent operational state (known DAOs / recent proposals surfaced by
# dexe_context). Default ~/.dexe-mcp/state.json. Override to a writable path.
# DEXE_STATE_PATH=
# Override the DeXe-Protocol checkout path (auto-managed when unset).
# DEXE_PROTOCOL_PATH=

# ─────────────────────────────────────────────────────────────────────────
# Swarm testing harness (scripts/swarm/*) — ALL OPTIONAL.
# Required only when running `npm run swarm:*` against BSC mainnet.
# ─────────────────────────────────────────────────────────────────────────

# Two-stage strategy: contract scenarios (S00–S21) run on BSC TESTNET (chain 97,
# free faucet BNB). Subgraph + DeXe backend scenarios (S22–S25, S12, S14) run on
# MAINNET only because the indexer + API don't exist on testnet. Switch chains
# by changing SWARM_CHAIN_ID — scripts auto-pick the matching DAO/token list and
# RPC URL below.
SWARM_CHAIN_ID=97

# Per-chain RPC. Falls back to DEXE_RPC_URL when unset.
SWARM_RPC_URL_TESTNET=https://data-seed-prebsc-1-s1.binance.org:8545
SWARM_RPC_URL_MAINNET=https://bsc-dataseed.binance.org

# Per-chain DAO allowlists. Hard rule: anything outside the active list is
# rejected by preflight + fund-pool + orchestrator.
#   Testnet — fill in once you deploy a fresh DAO via dexe_dao_build_deploy.
#   Mainnet — DeployTestDAO is the default; append more as you create them.
SWARM_DAOS_TESTNET=
SWARM_DAOS_MAINNET=0x3E224749a18dBF46FdAE027ba152B1d1D5B4568F

# Per-chain governance token allowlists. fund-pool refuses to transfer any
# token not in the active list — prevents accidentally draining a client
# wallet via misconfigured scenario.
SWARM_TOKENS_TESTNET=
SWARM_TOKENS_MAINNET=0x0051Cf7595BeEA1669a13d23A74B74E6415B721d

# Wallet pool. Each pool wallet plays a fixed role. Pre-fund per the table
# below. BSC fees are ~0.1 gwei → cents per tx, so seed amounts are small.
#   PK_1 = Proposer         (≥0.005 BNB + ≥50k DAO token)
#   PK_2..5 = Voters / Delegators (≥0.002 BNB + ≥20k token each)
#   PK_6..7 = Validators    (≥0.002 BNB)
#   PK_8 = Expert           (≥0.002 BNB + ≥5k token)
AGENT_PK_1=0x<key>
AGENT_PK_2=0x<key>
AGENT_PK_3=0x<key>
AGENT_PK_4=0x<key>
AGENT_PK_5=0x<key>
AGENT_PK_6=0x<key>
AGENT_PK_7=0x<key>
AGENT_PK_8=0x<key>

# Funder wallet — only ever sends to AGENT_PK_1..8 addresses, only ever
# transfers tokens listed in SWARM_TOKENS. Both invariants enforced in
# scripts/swarm/fund-pool.ts before any tx is broadcast.
AGENT_FUNDER_PK=0x<key>

# Swarm cost guard — preflight aborts if total spend across all wallets this
# calendar day already exceeds this BNB amount. Realistic 25-scenario sweep is
# ~0.008 BNB at current BSC fees, so this is a fat safety net, not a target.
# SWARM_DAILY_BNB_BUDGET=0.05

# ── Nightly poster + auto-fixer (scripts/swarm/nightly.sh) ───────────────
# After each sweep the orchestrator emits one greppable line:
#   SWARM <runId> <pass>/<total> <mode> <chainTag> <reportPath>
# nightly.sh forwards that line to either / both of:
#
# A. A GitHub issue comment (recommended — cheapest history). Set this to
#    the issue number created via `gh issue create --title "swarm: nightly status"`.
#    Requires `gh` CLI authenticated (`gh auth login`). Tracking issue for this
#    repo: https://github.com/edward-arinin-web-dev/dexe-mcp/issues/1
SWARM_SUMMARY_ISSUE=1
#
# B. A Slack-compatible incoming-webhook URL. Posts `{"text": "<summary>"}`.
# SWARM_SUMMARY_WEBHOOK=https://hooks.slack.com/services/T.../B.../...

# Auto-fixer opt-in. With SWARM_FIXER=1, nightly.sh will (eventually) spawn
# the fixer subagent on failure. It opens a `swarm-fix/<YYYY-MM-DD>` PR with
# diff scope hard-bounded to src/tools/, src/lib/, tests/swarm/. Default off.
# SWARM_FIXER=1
